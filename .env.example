PORT=8081
NODE_ENV=development

DATABASE_URL=postgres://postgres:postgres@localhost:5432/vcom_chat

# API principal de VCOM (usuarios/autenticacion)
VCOM_API_BASE_URL=https://vcamb.microwesttechnologies.com

# Permite CORS para la app Flutter Web/Desktop si aplica
CORS_ORIGIN=*

CHAT_ENABLE_MOCK_USERS=false
CHAT_UPLOAD_DIR=storage/chat-media
CHAT_PUBLIC_BASE_URL=

# Firebase Cloud Messaging (HTTP v1)
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_FILE=
# Alternativa al archivo: JSON completo serializado en una sola linea
FCM_SERVICE_ACCOUNT_JSON=
